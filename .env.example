# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (ваш личный ID или ID группы)
TELEGRAM_CHAT_ID=your_chat_id_here

# Интервал проверки в минутах (по умолчанию 60)
CHECK_INTERVAL_MINUTES=60

# Ключевые слова для поиска (через запятую)
SEARCH_KEYWORDS=бизнес-аналитик,business analyst,BA,системный аналитик

# Регион поиска для hh.ru (1 = Москва, 2 = Санкт-Петербург, 0 = вся Россия)
HH_AREA=1

# Минимальная зарплата для фильтрации (0 = без фильтра)
MIN_SALARY=0

# Опыт работы: noExperience, between1And3, between3And6, moreThan6 (пусто = любой)
EXPERIENCE=

# Путь к файлу БД
DB_PATH=jobs.db
